# Copy to .env and fill in real values. Never commit .env.
PORT=8787

# Master key for encrypting credentials stored via the Settings UI (AI API key,
# SMTP password) — AES-256-GCM at rest. It lives ONLY here, never in the DB, so a
# leaked database/backup holds useless ciphertext. Required in production before
# you can save those secrets in the UI. Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SETTINGS_KEY=change-me-to-a-long-random-string

# Where the internal web app is served from (CORS + CSRF origin check). In dev
# this is the Vite port. In production the API serves the app itself, so leave
# it as the prod origin.
WEB_ORIGIN=http://localhost:5173

# Set to 1 ONLY behind a reverse proxy you run (nginx): the API then trusts
# X-Forwarded-For for rate limiting and the audit trail.
TRUST_PROXY=0

# development | production
NODE_ENV=development

# SQLite database location. Sessions live in the DB too — no session secret needed.
DB_PATH=./data/leads.db

# --- AI core ---------------------------------------------------------------
# AI_BASE_URL / AI_MODEL / AI_LABEL / AI_API_KEY and the SMTP_* block below can
# also be set from the Settings page (Einstellungen) at runtime — values there
# override these, and the secrets are encrypted at rest with SETTINGS_KEY. These
# env vars remain the fallback, so an .env-only setup keeps working unchanged.
#
# OpenLeads talks the OpenAI-compatible Chat Completions protocol, so it runs
# against any serving stack. Defaults target a LOCAL Ollama — self-hosted, open
# weights, zero data egress (the DSGVO-friendly default).
#
# Quick start (open source, on your own machine):
#   1) install Ollama, then:  ollama pull llama3.1:8b
#   2) leave the defaults below as-is.
AI_BASE_URL=http://localhost:11434/v1
AI_MODEL=llama3.1:8b
# Only needed for hosted OpenAI-compatible endpoints (Mistral, vLLM w/ key, …).
AI_API_KEY=
# Optional friendly label shown in the UI, e.g. "Teuken-7B · self-hosted (EU)".
AI_LABEL=
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=1024
AI_TIMEOUT_MS=120000

# --- Outreach e-mail (SMTP) ------------------------------------------------
# Optional. Only an *approved* (freigegeben) draft can ever be sent, and every
# message gets an Impressum + opt-out appended automatically (UWG §7 / Art. 21
# DSGVO). Leave blank to disable sending entirely.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false            # true for port 465 (implicit TLS)
SMTP_USER=
SMTP_PASS=
SMTP_FROM=                   # e.g. "Meine Firma <hallo@example.de>"
