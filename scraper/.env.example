# Copy to .env and fill in. Never commit .env.

# Anthropic API key for the Sonnet discovery step (https://console.anthropic.com).
ANTHROPIC_API_KEY=sk-ant-...

# The CRM API the scraper posts leads to.
CRM_API_URL=http://127.0.0.1:8787
# Must match SERVICE_TOKEN in crm/api/.env
CRM_SERVICE_TOKEN=change-me-scraper-token

# Minimum outdatedness score required to post a lead (0-100). Default 40.
MIN_SCORE=40

# Discovery model, only for running the scraper standalone (defaults to
# claude-sonnet-4-6). When started from the CRM UI, the scraper uses the app's
# configured default AI model instead — there is no separate model setting there.
# SCRAPER_MODEL=claude-sonnet-4-6

# Scan raster. Prefer setting these in the CRM (Settings → Lead-Scraper); the
# scraper pulls that config at startup. These env vars are a fallback/override.
# Towns and region ship empty — set them for your area (nothing is Munich-locked).
# SCRAPER_TRADES=Schreiner,Maler,Dachdecker
# SCRAPER_TOWNS=Dachau,Erding,Freising

# Region phrase used in the discovery prompt. MUST match your TOWNS (e.g.
# "Großraum Hamburg"). Empty by default; an empty region just drops the anchor.
# SCRAPER_REGION=

# Politeness & safety when fetching candidate sites.
# SCRAPER_RESPECT_ROBOTS=true        # obey robots.txt (default true)
# SCRAPER_POLITE_DELAY_MS=800        # delay between site requests
# SCRAPER_USER_AGENT=                # override the identifying bot UA if needed
# SCRAPER_WEB_SEARCH_MAX_USES=5      # cap web searches per discovery call (cost guard)

# A copyright year older than (current year − this) counts as stale. Default 8.
# SCRAPER_STALE_YEARS=8
